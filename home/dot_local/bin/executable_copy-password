#!/usr/bin/env bash
#
# copy-password — Build and install CopyPassword.app with Karabiner shortcuts.
#
# Reads account definitions from ~/.config/copy-password/accounts.json and
# generates Karabiner-Elements complex-modification rules plus a small Swift
# macOS helper app that fetches passwords via the 1Password CLI (`op`).
#
# Usage:
#   copy-password --setup
#       Writes ~/.config/karabiner/karabiner.json and
#       builds + installs ~/Applications/CopyPassword.app.

readonly _SCRIPT_NAME="${0##*/}"

# ---------------------------------------------------------------------------
# Colour helpers (tput — no hardcoded escape sequences)
# ---------------------------------------------------------------------------
if [[ -t 1 ]]; then
  _COL_RED="$(tput setaf 1)"
  _COL_GRN="$(tput setaf 2)"
  _COL_BLU="$(tput setaf 4)"
  _COL_RST="$(tput sgr0)"
else
  _COL_RED="" _COL_GRN="" _COL_BLU="" _COL_RST=""
fi

_red()   { printf '%s%s%s' "${_COL_RED}" "$*" "${_COL_RST}"; }
_green() { printf '%s%s%s' "${_COL_GRN}" "$*" "${_COL_RST}"; }
_blue()  { printf '%s%s%s' "${_COL_BLU}" "$*" "${_COL_RST}"; }

err()  { printf '%s\n' "$(_red   "[${_SCRIPT_NAME}] ERROR: $*")" >&2; }
info() { printf '%s\n' "$(_blue  "[${_SCRIPT_NAME}] $*")"; }
ok()   { printf '%s\n' "$(_green "[${_SCRIPT_NAME}] $*")"; }

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
  cat <<EOF
Usage:
  ${_SCRIPT_NAME} --setup   Build CopyPassword.app and write Karabiner config
EOF
}

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
readonly _ACCOUNTS_CONFIG="${HOME}/.config/copy-password/accounts.json"
readonly _KARABINER_CONFIG="${HOME}/.config/karabiner/karabiner.json"
# Must be the absolute binary path; Karabiner runs shell_command without $PATH.
readonly _APP_BIN="${HOME}/Applications/CopyPassword.app/Contents/MacOS/CopyPassword"
readonly _SHELL_PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

# ---------------------------------------------------------------------------
# find_op — locate the 1Password CLI binary
# ---------------------------------------------------------------------------
find_op() {
  local candidate
  for candidate in /opt/homebrew/bin/op /usr/local/bin/op; do
    if [[ -x "${candidate}" ]]; then
      printf '%s' "${candidate}"
      return 0
    fi
  done
  return 1
}

# ---------------------------------------------------------------------------
# map_modifier — map shortcut modifier names to Karabiner key names
# ---------------------------------------------------------------------------
map_modifier() {
  case "$1" in
    fn)        printf 'fn' ;;
    ctrl)      printf 'left_control' ;;
    shift)     printf 'left_shift' ;;
    alt|opt)   printf 'left_option' ;;
    cmd)       printf 'left_command' ;;
    *)         err "Unknown modifier: $1"; return 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# load_accounts — read and validate accounts config; output JSON to stdout
# ---------------------------------------------------------------------------
load_accounts() {
  if [[ ! -f "${_ACCOUNTS_CONFIG}" ]]; then
    info "No accounts config at ${_ACCOUNTS_CONFIG} — nothing to do."
    return 1
  fi

  local accounts
  accounts="$(cat "${_ACCOUNTS_CONFIG}")"

  # Treat empty array as "no accounts"
  local count
  count="$(printf '%s' "${accounts}" | jq 'length')" || {
    err "Failed to parse ${_ACCOUNTS_CONFIG}"; return 1
  }
  if [[ "${count}" -eq 0 ]]; then
    info "Accounts config is empty — nothing to do."
    return 1
  fi

  printf '%s' "${accounts}"
}

# ---------------------------------------------------------------------------
# cmd_build_app — compile and install ~/Applications/CopyPassword.app
# ---------------------------------------------------------------------------
cmd_build_app() {
  command -v swiftc &>/dev/null \
    || { err "swiftc not found. Install Xcode Command Line Tools: xcode-select --install"; return 1; }

  local op_path
  op_path="$(find_op)" || { err "1Password CLI (op) not found"; return 1; }

  local build_dir
  build_dir="$(mktemp -d)" || { err "Failed to create build directory"; return 1; }
  # shellcheck disable=SC2064
  trap "rm -rf '${build_dir}'" RETURN

  info "Building CopyPassword.app…"

  # --- Swift source ---
  cat > "${build_dir}/CopyPassword.swift" <<SWIFT_EOF
import Cocoa
import UserNotifications

// ---------------------------------------------------------------------------
// Argument parsing
// ---------------------------------------------------------------------------
private func parseArgs() -> (label: String, opUri: String) {
  var args = Array(CommandLine.arguments.dropFirst())
  var label = ""
  var opUri = ""
  while !args.isEmpty {
    let arg = args.removeFirst()
    switch arg {
    case "--label":
      guard let value = args.first else {
        fputs("--label requires a value\n", stderr); exit(1)
      }
      args.removeFirst()
      label = value
    case "--op-uri":
      guard let value = args.first else {
        fputs("--op-uri requires a value\n", stderr); exit(1)
      }
      args.removeFirst()
      opUri = value
    default:
      if arg.hasPrefix("--label=") {
        label = String(arg.dropFirst("--label=".count))
      } else if arg.hasPrefix("--op-uri=") {
        opUri = String(arg.dropFirst("--op-uri=".count))
      }
    }
  }
  guard !label.isEmpty, !opUri.isEmpty else {
    fputs("Usage: CopyPassword --label <label> --op-uri <uri>\n", stderr)
    exit(1)
  }
  return (label, opUri)
}

// ---------------------------------------------------------------------------
// Find op binary
// ---------------------------------------------------------------------------
private func findOp() -> String {
  for path in ["/opt/homebrew/bin/op", "/usr/local/bin/op"] {
    if FileManager.default.isExecutableFile(atPath: path) {
      return path
    }
  }
  fputs("1Password CLI (op) not found\n", stderr)
  exit(1)
}

// ---------------------------------------------------------------------------
// Password retrieval via op CLI
// ---------------------------------------------------------------------------
private func fetchPassword(opUri: String, label: String) -> String {
  let opPath = findOp()
  let process = Process()
  process.executableURL = URL(fileURLWithPath: opPath)
  process.arguments     = ["read", opUri]
  let outPipe = Pipe()
  process.standardOutput = outPipe
  process.standardError  = Pipe()
  do    { try process.run() } catch {
    fputs("Failed to launch op: \(error)\n", stderr); exit(1)
  }
  process.waitUntilExit()
  guard process.terminationStatus == 0 else {
    fputs("op exited \(process.terminationStatus) for \(label). Is 1Password unlocked?\n", stderr)
    exit(1)
  }
  let raw = outPipe.fileHandleForReading.readDataToEndOfFile()
  let pw  = (String(data: raw, encoding: .utf8) ?? "").trimmingCharacters(in: .newlines)
  if pw.isEmpty {
    fputs("Empty password for \(label). Is 1Password unlocked?\n", stderr); exit(1)
  }
  return pw
}

// ---------------------------------------------------------------------------
// Clipboard
// ---------------------------------------------------------------------------
private func copyToClipboard(_ string: String) {
  NSPasteboard.general.clearContents()
  NSPasteboard.general.setString(string, forType: .string)
}

// ---------------------------------------------------------------------------
// App delegate — notification delivery
// ---------------------------------------------------------------------------
final class AppDelegate: NSObject, NSApplicationDelegate, UNUserNotificationCenterDelegate {
  private let label: String
  init(label: String) { self.label = label }

  func applicationDidFinishLaunching(_ note: Notification) {
    let center = UNUserNotificationCenter.current()
    center.delegate = self
    center.requestAuthorization(options: [.alert]) { [weak self] granted, _ in
      guard granted, let self else { NSApplication.shared.terminate(nil); return }
      self.send(center: center)
    }
  }

  private func send(center: UNUserNotificationCenter) {
    let content      = UNMutableNotificationContent()
    content.title    = "copy-password"
    content.body     = "\(label) password copied"
    let request      = UNNotificationRequest(identifier: UUID().uuidString,
                                             content: content, trigger: nil)
    center.add(request) { _ in
      DispatchQueue.main.asyncAfter(deadline: .now() + 0.5) {
        NSApplication.shared.terminate(nil)
      }
    }
  }

  // Show notification even when the app is technically active
  func userNotificationCenter(_ c: UNUserNotificationCenter,
                              willPresent n: UNNotification,
                              withCompletionHandler h: @escaping (UNNotificationPresentationOptions) -> Void) {
    h([.banner])
  }
}

// ---------------------------------------------------------------------------
// Entry point — synchronous work first, then run loop for notification
// ---------------------------------------------------------------------------
let (label, opUri)  = parseArgs()
let password        = fetchPassword(opUri: opUri, label: label)
copyToClipboard(password)

let app             = NSApplication.shared
app.setActivationPolicy(.accessory)   // no Dock icon, no menu bar
let delegate        = AppDelegate(label: label)
app.delegate        = delegate
app.run()
SWIFT_EOF

  # --- Info.plist ---
  local app_dir="${build_dir}/CopyPassword.app/Contents"
  mkdir -p "${app_dir}/MacOS" "${app_dir}/Resources"

  cat > "${app_dir}/Info.plist" <<'PLIST_EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>   <string>CopyPassword</string>
  <key>CFBundleIdentifier</key>   <string>local.copy-password</string>
  <key>CFBundleName</key>         <string>CopyPassword</string>
  <key>CFBundleVersion</key>      <string>1</string>
  <key>CFBundleIconFile</key>     <string>AppIcon</string>
  <key>NSPrincipalClass</key>     <string>NSApplication</string>
  <key>LSUIElement</key>          <true/>
</dict>
</plist>
PLIST_EOF

  # --- Compile ---
  swiftc "${build_dir}/CopyPassword.swift" \
    -o "${app_dir}/MacOS/CopyPassword" \
    -framework Cocoa \
    -framework UserNotifications \
    2>&1 || { err "Swift compilation failed"; return 1; }

  # --- Icon (copy 1Password's icon) ---
  cp /Applications/1Password.app/Contents/Resources/icon.icns \
     "${app_dir}/Resources/AppIcon.icns" \
    || { err "Could not copy 1Password icon"; return 1; }

  # --- Ad-hoc sign ---
  codesign --sign - --force --deep "${build_dir}/CopyPassword.app" 2>/dev/null \
    || { err "codesign failed"; return 1; }

  # --- Install ---
  mkdir -p "${HOME}/Applications"
  rm -rf "${HOME}/Applications/CopyPassword.app"
  cp -R "${build_dir}/CopyPassword.app" "${HOME}/Applications/CopyPassword.app"

  ok "CopyPassword.app installed to ~/Applications"
  info "First run will show a 'CopyPassword wants to send notifications' dialog — click Allow."
}

# ---------------------------------------------------------------------------
# build_karabiner_rule — emit a single Karabiner rule JSON object for an
#   account entry.  Reads shortcut string (e.g. "ctrl+fn+p"), label, and
#   op URI; writes JSON to stdout.
# ---------------------------------------------------------------------------
build_karabiner_rule() {
  local label=""
  local shortcut=""
  local op=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --label)    label=${2?$1: parameter value not set} && shift 2 ;;
      --label=*)  label=${1#*=} && shift ;;
      --shortcut) shortcut=${2?$1: parameter value not set} && shift 2 ;;
      --shortcut=*) shortcut=${1#*=} && shift ;;
      --op)       op=${2?$1: parameter value not set} && shift 2 ;;
      --op=*)     op=${1#*=} && shift ;;
      *) err "build_karabiner_rule: unknown argument: $1"; return 1 ;;
    esac
  done

  # Split shortcut on '+': last part is the key, rest are modifiers
  IFS='+' read -ra parts <<< "${shortcut}"
  local key="${parts[-1]}"
  local modifiers=()
  local i
  for (( i=0; i < ${#parts[@]} - 1; i++ )); do
    local mapped
    mapped="$(map_modifier "${parts[$i]}")" || return 1
    modifiers+=("${mapped}")
  done

  # Build modifier_count for sorting (more modifiers = more specific)
  local modifier_count="${#modifiers[@]}"

  # Build modifiers JSON array
  local mods_json="[]"
  if [[ ${#modifiers[@]} -gt 0 ]]; then
    mods_json="$(printf '%s\n' "${modifiers[@]}" | jq -R . | jq -s .)"
  fi

  # Build the description
  local desc_parts=()
  for (( i=0; i < ${#parts[@]} - 1; i++ )); do
    # Capitalize first letter of each modifier for the description
    local part="${parts[$i]}"
    desc_parts+=("${part^}")
  done
  desc_parts+=("${key^^}")
  local description
  description="$(IFS='+'; printf '%s' "${desc_parts[*]}")"
  description="${description}: Copy ${label} password"

  # Build the shell_command
  local shell_cmd="PATH=${_SHELL_PATH} HOME=\${HOME} ${_APP_BIN} --label '${label}' --op-uri '${op}'"

  # Emit JSON with a _modifier_count field for sorting (stripped later)
  jq -n \
    --arg desc "${description}" \
    --arg key_code "${key}" \
    --argjson modifiers "${mods_json}" \
    --arg shell_cmd "${shell_cmd}" \
    --argjson mod_count "${modifier_count}" \
    '{
      _modifier_count: $mod_count,
      description: $desc,
      manipulators: [
        {
          type: "basic",
          from: {
            key_code: $key_code,
            modifiers: {
              mandatory: $modifiers
            }
          },
          to: [
            {
              shell_command: $shell_cmd
            }
          ]
        }
      ]
    }'
}

# ---------------------------------------------------------------------------
# cmd_setup — write ~/.config/karabiner/karabiner.json
# ---------------------------------------------------------------------------
cmd_setup() {
  local accounts
  accounts="$(load_accounts)" || return 0

  command -v jq &>/dev/null \
    || { err "jq not found. Install it: brew install jq"; return 1; }

  mkdir -p "$(dirname "${_KARABINER_CONFIG}")"

  # --- Build rules array ---
  # Start with the hardcoded Caps Lock → Globe rule
  local caps_lock_rule
  caps_lock_rule="$(jq -n '{
    _modifier_count: 999,
    description: "Caps Lock to Globe (fn)",
    manipulators: [
      {
        type: "basic",
        from: {
          key_code: "caps_lock",
          modifiers: { optional: ["any"] }
        },
        to: [{ key_code: "fn" }]
      }
    ]
  }')"

  local all_rules="[${caps_lock_rule}]"

  # Generate a rule for each account
  local count
  count="$(printf '%s' "${accounts}" | jq 'length')"
  local idx
  for (( idx=0; idx < count; idx++ )); do
    local label shortcut op_uri
    label="$(printf '%s' "${accounts}" | jq -r ".[$idx].label")"
    shortcut="$(printf '%s' "${accounts}" | jq -r ".[$idx].shortcut")"
    op_uri="$(printf '%s' "${accounts}" | jq -r ".[$idx].op")"

    local rule
    rule="$(build_karabiner_rule \
      --label "${label}" \
      --shortcut "${shortcut}" \
      --op "${op_uri}")" || return 1

    all_rules="$(printf '%s' "${all_rules}" | jq --argjson rule "${rule}" '. + [$rule]')"
  done

  # Sort: more-specific (more modifiers) first, then strip _modifier_count
  local sorted_rules
  sorted_rules="$(printf '%s' "${all_rules}" \
    | jq 'sort_by(-._modifier_count) | map(del(._modifier_count))')"

  # --- Assemble full Karabiner config ---
  local karabiner_config
  karabiner_config="$(jq -n \
    --argjson rules "${sorted_rules}" \
    '{
      global: {
        show_in_menu_bar: true
      },
      profiles: [
        {
          name: "Default profile",
          selected: true,
          complex_modifications: {
            rules: $rules
          },
          virtual_hid_keyboard: {
            keyboard_type_v2: "ansi"
          }
        }
      ]
    }')"

  printf '%s\n' "${karabiner_config}" > "${_KARABINER_CONFIG}"

  ok "Karabiner config written to ${_KARABINER_CONFIG}"
  info "Next steps:"
  info "  1. Open Karabiner-Elements → Misc tab → Reload JSON (or restart the app)"
  info "  2. Verify the rules appear under Complex Modifications"
  cmd_build_app || return 1
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
main() {
  local setup=false

  while [[ $# -gt 0 ]]; do
    case $1 in
      --setup)     setup=true && shift ;;
      --help | -h) usage && return 0 ;;
      *) err "Unknown argument: $1"; usage >&2; return 1 ;;
    esac
  done

  if [[ "${setup}" == true ]]; then
    cmd_setup
  else
    usage >&2
    return 1
  fi
}

main "$@"
