#!/usr/bin/env bash
# Purpose: Upgrade the typical developer tooling on this machine.
# Usage:   upgrade-all
#
# Each step is skipped if the tool isn't installed. A failure in one step
# does not abort the remaining steps.

set -uo pipefail

step() { printf '\n\033[1;33m⚙ %s\033[0m\n' "$1"; }

if command -v brew &>/dev/null; then
  step "Homebrew formulae & casks"

  # Drop taps that have been merged upstream and would otherwise fail `brew update`.
  # Add new entries here as Homebrew retires more taps over time.
  deprecated_taps=(
    homebrew/cask-versions  # merged into homebrew/cask (2023)
    homebrew/cask-fonts     # merged into homebrew/cask (2024)
  )
  for tap in "${deprecated_taps[@]}"; do
    if brew tap | grep -qx "$tap"; then
      printf '  ↗ untapping deprecated %s\n' "$tap"
      brew untap "$tap" || true
    fi
  done

  brew update
  brew upgrade

  # `brew upgrade` skips formulas without bottles to avoid slow source builds
  # in the middle of a batch. Anything still listed in `brew outdated` after
  # the first pass is unbottled — rebuild it from source so tap formulas
  # don't accumulate stale versions indefinitely.
  unbottled=$(brew outdated --formula --quiet)
  if [ -n "$unbottled" ]; then
    printf '  ⚙ rebuilding unbottled formulae from source: %s\n' "$(echo "$unbottled" | tr '\n' ' ')"
    # shellcheck disable=SC2086 # intentional word splitting
    brew upgrade --build-from-source $unbottled || true
  fi

  brew cleanup
fi

if command -v mas &>/dev/null; then
  step "Mac App Store"
  mas upgrade
fi

if command -v npm &>/dev/null; then
  step "Global npm packages"
  npm update -g
fi

# Skip Apple's frozen system Ruby (/usr/bin/gem) — its 2.6.x is too old for
# modern gems and `gem update` just churns failures. If a real Ruby (brew,
# rbenv, asdf, ...) gets installed, `gem` resolves elsewhere and this runs.
if command -v gem &>/dev/null && [ "$(command -v gem)" != /usr/bin/gem ]; then
  step "Ruby gems"
  gem update --user-install
fi

if command -v gh &>/dev/null; then
  step "gh extensions"
  gh extension upgrade --all
fi

step "macOS system updates (listing only)"
softwareupdate -l
