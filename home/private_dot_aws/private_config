# Static AWS access keys removed 2026-05-01 in favor of SSO via Authentik passkey.
# Profiles are configured in ~/.aws/config (sso-session bkahlert + profiles prod/dev).
# Sign in with: aws sso login --profile prod

[default]
region = eu-central-1
output = json

# --- SSO via Authentik passkey (primary) ---

[sso-session bkahlert]
sso_start_url = https://choam.awsapps.com/start
sso_region = eu-central-1
sso_registration_scopes = sso:account:access

[profile prod]
sso_session = bkahlert
sso_account_id = 709387325224
sso_role_name = AdministratorAccess
region = eu-central-1
output = json

[profile dev]
sso_session = bkahlert
sso_account_id = 382728805609
sso_role_name = AdministratorAccess
region = us-east-1
output = json
