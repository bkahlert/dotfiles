#!/usr/bin/env bash
# Test harness for the Claude Code status line script.
# Usage: ./statusline-test [path-to-input.json]
#
# Runs the status line script three times:
#   1. auto-detection (default behavior)
#   2. Nerd Font icons enforced (--nerd-fonts)
#   3. emoji fallbacks enforced (--no-nerd-fonts)

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
input_file="${1:-"$script_dir/statusline-input.json"}"
# Support running from the chezmoi source tree (executable_statusline) or installed location (statusline)
if [[ -x "$script_dir/statusline" ]]; then
  statusline="$script_dir/statusline"
elif [[ -x "$script_dir/executable_statusline" ]]; then
  statusline="$script_dir/executable_statusline"
else
  statusline="$HOME/.claude/statusline"
fi

dim=$'\033[2m' reset=$'\033[0m'

if [[ ! -f "$input_file" ]]; then
  printf '\033[31m✘\033[0m input file not found: %s\n' "$input_file" >&2
  exit 1
fi

if [[ ! -x "$statusline" ]]; then
  printf '\033[31m✘\033[0m statusline script not found or not executable: %s\n' "$statusline" >&2
  exit 1
fi

run() {
  local label="$1"; shift
  printf '%s%s%s ' "$dim" "$label" "$reset" >&2
  "$statusline" "$@" < "$input_file"
}

printf '\033[33mⓘ\033[0m  input:  %s\n' "$input_file" >&2
printf '\033[33mⓘ\033[0m  script: %s\n' "$statusline" >&2
printf '%s──────────────────────────────%s\n' "$dim" "$reset" >&2

run "auto:      "
run "nerd-font: " --nerd-fonts
run "fallback:  " --no-nerd-fonts
